<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>TimeBlock - Tracker</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/nav') %>

    <main>
        <h1>Daily Tracker</h1>

        <form method="POST" action="/tracker">
            <input type="text" name="time" placeholder="08:00" required>
            <input type="text" name="activity" placeholder="Activity" required>
            <input type="text" name="project" placeholder="Project">
            <button type="submit">Add block</button>
        </form>

        <table>
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Activity</th>
                    <th>Project</th>
                </tr>
            </thead>
            <tbody>
                <% blocks.forEach(function(block) { %>
                    <tr>
                        <td><%= block.time %></td>
                        <td><%= block.activity %></td>
                        <td><%= block.project %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
